APP_URL=https://app.mahly.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres-service-name
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=database # Use database if you run a separate worker container

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=failover
# MAIL_SCHEME=null
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@mahly.org"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=
BREVO_MAILER_HOST=smtp-relay.brevo.com
BREVO_MAILER_PORT=587
BREVO_MAILER_USERNAME=a6f358001@smtp-brevo.com
BREVO_MAILER_PASSWORD=
BREVO_MAILER_ENCRYPTION=tls

GOOGLE_MAPS_API_KEY=
EXCHANGE_RATE_API_URL=https://lirascope.syria-cloud.sy/api/v1/rates/latest
EXCHANGE_RATE_API_KEY=
USD_TO_SYP_FALLBACK_RATE=13000
USD_TO_SYP_MANUAL_RATE=
PRICE_MIGRATION_SYP_TO_USD_RATE=12000
EXCHANGE_RATE_TIMEOUT_SECONDS=10
EXCHANGE_RATE_CACHE_TTL_SECONDS=14400
USD_TO_SYP_MARKET_RATE_SCALE_FACTOR=100
USD_TO_SYP_SOURCE_PREFERENCE=market
USD_TO_SYP_MARKET_RATE_SIDE=sell

# Optional: keep only if you use AWS services (e.g. SQS) elsewhere.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

VITE_APP_NAME="${APP_NAME}"
MAHLY_ADMIN_PASSWORD=

